<div class="footer-wrapper">
    <footer class="footer">
        <div class="footer-container">
            <div style="display:flex;flex-wrap:wrap;gap:2rem;align-items:flex-start;justify-content:space-between;">
                <!-- Left: Logo + Version + MAAGE links -->
                <div style="flex:0 0 180px;min-width:180px;">
                    <div class="footer-logo-container">
                        <a href="/" aria-label="MAAGE" class="footer-logo-link flex flex-row items-center">
                            <img src="/maage/img/logos/maage-logo-temp.png" alt="MAAGE Logo" class="footer-logo"
                                style="height:32px; width:auto;" />
                            <div class="footer-logo-text ml-2 flex items-center" style="line-height:1;">
                                <span class="logo-first">MA</span>
                                <span class="logo-last">AGE</span>
                            </div>
                        </a>
                    </div>
                    <div class="mt-1" style="text-align:center;">
                        <span class="font-poppins text-[13px] font-light text-white">v<%- request.package.version %></span>
                    </div>

                </div>

                <!-- Center: Funding Statement -->
                <div style="flex:1 1 400px;max-width:550px;text-align:center;margin:0 auto;">
                    <h4 class="font-inter font-semibold text-[18px] text-maage-text-white mt-0 mb-3">Funding Statement</h4>
                    <p class="font-poppins text-[13px] font-light text-white leading-relaxed">
                        This project is supported by the Centers for Disease Control and Prevention (CDC) of the U.S. Department of Health and Human Services (HHS) through a financial assistance award to the Illinois Department of Public Health (IDPH). The contents are solely the responsibility of IDPH and its partners and do not necessarily represent the official views of, nor imply endorsement by, CDC/HHS or the U.S. Government.
                    </p>
                </div>

                <!-- Right: Social Media Links -->
                <div style="flex:0 0 260px;min-width:260px;text-align:right;">
                    <h4 class="font-inter font-semibold text-[18px] text-maage-text-white mt-0 mb-3 whitespace-nowrap">Connect with MAAGE</h4>
                    <div class="flex space-x-4" style="justify-content:flex-end;">
                        <a href="https://github.com/MAAGE-BRC" aria-label="Github"
                            class="inline-block hover:opacity-80 transition-opacity cursor-pointer">
                            <img src="/maage/fontawesome/svg/github.svg" alt="GitHub Icon"
                                class="w-8 h-8 transform transition-transform duration-300 hover:scale-110" />
                        </a>
                        <a href="https://www.twitter.com/maage_brc" aria-label="Twitter"
                            class="inline-block hover:opacity-80 transition-opacity cursor-pointer">
                            <img src="/maage/fontawesome/svg/x-twitter.svg" alt="X Icon; Twitter Icon"
                                class="w-8 h-8 transform transition-transform duration-300 hover:scale-110" />
                        </a>
                        <a href="https://www.linkedin.com/company/maage-brc" aria-label="LinkedIn"
                            class="inline-block hover:opacity-80 transition-opacity cursor-pointer">
                            <img src="/maage/fontawesome/svg/linkedin.svg" alt="LinkedIn Icon"
                                class="w-8 h-8 transform transition-transform duration-300 hover:scale-110" />
                        </a>
                        <a href="mailto:help@maage-brc.org" aria-label="Email"
                            class="inline-block hover:opacity-80 transition-opacity cursor-pointer">
                            <img src="/maage/fontawesome/svg/envelope.svg" alt="Email Envelope Icon"
                                class="w-8 h-8 transform transition-transform duration-300 hover:scale-110" />
                        </a>
                    </div>
                </div>
            </div>
            <style>
                .footer-wrapper a:visited {
                    color: #f5f5f5;
                }
                .footer-nav-section a,
                .footer-nav-section a:visited,
                .footer-nav-section a:active {
                    color: #f5f5f5 !important;
                }
            </style>
        </div>
    </footer>
</div>